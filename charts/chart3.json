      "mark": { "type": "point", "filled": true, "opacity": 0.85, "stroke": "rgba(0,0,0,0.08)", "strokeWidth": 0.5 },
      "encoding": {
        "x": { "field": "temp_anom", "type": "quantitative", "title": "Annual Temperature Anomaly (°C above 1961-1990 average)", "axis": { "titleColor": "#888", "titleFont": "DM Mono", "titleFontSize": 10, "labelColor": "#888", "labelFont": "DM Mono", "grid": true, "gridColor": "#e8e0d0", "domainColor": "#ccc" } },
        "y": { "field": "area", "type": "quantitative", "title": "Total Area Burned (Million ha)", "axis": { "titleColor": "#888", "titleFont": "DM Mono", "titleFontSize": 10, "labelColor": "#888", "labelFont": "DM Mono", "grid": true, "gridColor": "#e8e0d0", "domainColor": "#ccc" } },
        "size": { "field": "rain_deficit", "type": "quantitative", "title": "Rainfall Deficit (mm)", "scale": { "range": [40, 1100] }, "legend": { "labelColor": "#888", "titleColor": "#888", "labelFont": "DM Mono", "titleFont": "DM Mono", "orient": "bottom-right" } },
        "color": { "field": "ffdi_days", "type": "quantitative", "title": "Dangerous Fire Days", "scale": { "scheme": "orangered" }, "legend": { "labelColor": "#888", "titleColor": "#888", "labelFont": "DM Mono", "titleFont": "DM Mono", "orient": "bottom-left", "gradientLength": 100 } },
        "tooltip": [{ "field": "year", "title": "Season" }, { "field": "temp_anom", "title": "Temp Anomaly (°C)", "format": ".1f" }, { "field": "area", "title": "Area Burned (M ha)", "format": ".1f" }, { "field": "rain_deficit", "title": "Rainfall Deficit (mm)" }, { "field": "ffdi_days", "title": "Dangerous Fire Days" }]
      }
    },
    {
      "mark": { "type": "line", "strokeDash": [5,3], "strokeWidth": 1.5, "color": "rgba(184,61,16,0.3)" },
      "transform": [{ "regression": "area", "on": "temp_anom" }],
      "encoding": { "x": { "field": "temp_anom", "type": "quantitative" }, "y": { "field": "area", "type": "quantitative" } }
    },
    {
      "mark": { "type": "text", "align": "left", "dx": 12, "fontSize": 10, "font": "DM Mono", "fontWeight": 500 },
      "transform": [{ "filter": "datum.label !== ''" }],
      "encoding": { "x": { "field": "temp_anom", "type": "quantitative" }, "y": { "field": "area", "type": "quantitative" }, "text": { "field": "label" }, "color": { "condition": { "test": "datum.label === 'Black Summer'", "value": "#b83d10" }, "value": "#9a7820" } }
    }
