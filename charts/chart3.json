  "layer": [
    {
      "mark": { "type": "point", "filled": true, "opacity": 0.85 },
      "encoding": {
        "x": {
          "field": "temp_anomaly", "type": "quantitative",
          "title": "Annual Temperature Anomaly (°C above 1961–1990 average)",
          "axis": { "titleColor": "#aaa", "labelColor": "#888", "titleFont": "DM Mono", "labelFont": "DM Mono", "titleFontSize": 10, "grid": true, "gridColor": "rgba(255,255,255,.08)", "domainColor": "rgba(255,255,255,.2)" }
        },
        "y": {
          "field": "area_mha", "type": "quantitative",
          "title": "Total Area Burned (Million ha)",
          "axis": { "titleColor": "#aaa", "labelColor": "#888", "titleFont": "DM Mono", "labelFont": "DM Mono", "titleFontSize": 10, "grid": true, "gridColor": "rgba(255,255,255,.08)", "domainColor": "rgba(255,255,255,.2)" }
        },
        "size": {
          "field": "rainfall_deficit", "type": "quantitative",
          "title": "Rainfall Deficit (mm)",
          "scale": { "range": [40, 900] },
          "legend": { "orient": "bottom", "titleColor": "#aaa", "labelColor": "#888", "titleFont": "DM Mono", "labelFont": "DM Mono", "titleFontSize": 10, "labelFontSize": 9, "columns": 4, "symbolLimit": 5 }
        },
        "color": {
          "field": "fire_days", "type": "quantitative",
          "title": "Dangerous Fire Days",
          "scale": { "scheme": "orangered", "domain": [10, 90] },
          "legend": { "orient": "bottom", "titleColor": "#aaa", "labelColor": "#888", "titleFont": "DM Mono", "labelFont": "DM Mono", "titleFontSize": 10, "labelFontSize": 9, "gradientLength": 180, "gradientThickness": 8, "direction": "horizontal" }
        },
        "tooltip": [
          { "field": "season",          "title": "Fire Season" },
          { "field": "temp_anomaly",    "title": "Temp Anomaly (°C)", "format": ".2f" },
          { "field": "area_mha",        "title": "Area Burned (M ha)", "format": ".1f" },
          { "field": "rainfall_deficit","title": "Rainfall Deficit (mm)" },
          { "field": "fire_days",       "title": "Dangerous Fire Days" }
        ]
      }
    },
    {
      "mark": { "type": "text", "align": "left", "dx": 8, "dy": -4, "fontSize": 11, "font": "DM Mono", "fontWeight": 600 },
      "transform": [ { "filter": "datum.label != null" } ],
      "encoding": {
        "x": { "field": "temp_anomaly", "type": "quantitative" },
        "y": { "field": "area_mha", "type": "quantitative" },
        "text": { "field": "label" },
        "color": {
          "field": "fire_days", "type": "quantitative",
          "scale": { "scheme": "orangered", "domain": [10, 90] }
        }
      }
    },
    {
      "mark": { "type": "line", "color": "rgba(232,82,10,.3)", "strokeDash": [4,4], "strokeWidth": 1 },
      "transform": [ { "regression": "area_mha", "on": "temp_anomaly" } ],
      "encoding": {
        "x": { "field": "temp_anomaly", "type": "quantitative" },
        "y": { "field": "area_mha", "type": "quantitative" }
      }
    }
  ],
  "config": { "background": "transparent", "view": { "stroke": null } }
