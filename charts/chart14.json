              90,
              480,
              1120,
              2100
            ]
          },
          "legend": {
            "title": "Severity size",
            "orient": "bottom-left",
            "titleColor": "#f5eee7",
            "labelColor": "#e8ddd2",
            "titleFont": "DM Mono",
            "labelFont": "DM Mono",
            "titleFontSize": 10,
            "labelFontSize": 9,
            "titleLimit": 180,
            "symbolFillColor": "#5c220f",
            "symbolStrokeColor": "#f5eee7",
            "symbolOpacity": 0.95,
            "labelExpr": "datum.value===2?'Moderate to High':datum.value===3?'High':datum.value===4?'Very High':'Extreme'"
          }
        },
        "color": {
          "field": "severity",
          "type": "ordinal",
          "scale": {
            "domain": [
              2,
              3,
              4,
              5
            ],
            "range": [
