{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Projected Fire Hotspots Across Australia by 2070 (High Emissions, RCP 8.5)",
    "subtitle": "Each dot = a projected fire hotspot region. Size = relative fire frequency increase. Colour = severity. Click a dot for details.",
    "fontSize": 13,
    "subtitleFontSize": 10,
    "subtitleColor": "#888",
    "anchor": "start",
    "color": "#ffffff",
    "font": "Playfair Display, serif",
    "subtitleFont": "DM Mono, monospace"
  },
  "width": "container",
  "height": 480,
  "background": "transparent",
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -27
    ],
    "scale": 750
  },
  "params": [
    {
      "name": "dotClick",
      "select": {
        "type": "point",
        "on": "click",
        "fields": [
          "region"
        ]
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#1a0800",
        "stroke": "#3a1500",
        "strokeWidth": 1
      }
