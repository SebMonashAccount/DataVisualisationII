      "mark": {
        "type": "circle",
        "opacity": 0.82,
        "stroke": "#0d0000",
        "strokeWidth": 0.5
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "size": {
          "field": "freq_increase",
          "type": "quantitative",
          "scale": {
            "range": [
              120,
              1800
            ]
          },
          "legend": {
            "title": "Fire Freq. Increase (%)",
            "orient": "bottom-left",
            "titleColor": "#888",
            "labelColor": "#888",
            "titleFont": "DM Mono",
            "labelFont": "DM Mono",
            "titleFontSize": 9,
            "labelFontSize": 9
          }
        },
        "color": {
          "field": "severity",
          "type": "ordinal",
          "scale": {
            "domain": [
              2,
              3,
              4,
              5
            ],
            "range": [
              "#c9a227",
              "#e8520a",
              "#c0392b",
              "#8b0000"
            ]
          },
          "legend": {
            "title": "Severity",
            "orient": "bottom-right",
            "titleColor": "#888",
            "labelColor": "#888",
            "titleFont": "DM Mono",
            "labelFont": "DM Mono",
            "titleFontSize": 9,
            "labelFontSize": 9,
            "labelExpr": "datum.value===2?'Moderate-High':datum.value===3?'High':datum.value===4?'Very High':'Extreme'"
          }
        },
        "opacity": {
          "condition": {
            "param": "dotClick",
            "empty": true,
            "value": 0.82
          },
          "value": 0.25
        },
        "tooltip": [
          {
            "field": "region",
            "title": "Region"
          },
          {
            "field": "risk",
            "title": "Risk Level"
          },
          {
            "field": "freq_increase",
            "title": "Fire Frequency Increase (%)"
          },
          {
            "field": "detail",
            "title": "Outlook"
          }
        ]
