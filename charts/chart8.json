  },
  "params": [
    {
      "name": "groupSelect",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All","Mammal","Bird","Frog","Reptile","Invertebrate"],
        "labels": ["All Groups","Mammals","Birds","Frogs","Reptiles","Invertebrates"],
        "name": "Filter by group: "
      }
    }
  ],
  "transform": [
    {
      "filter": "groupSelect === 'All' || datum.group === groupSelect"
    }
  ],
  "layer": [
    {
      "mark": { "type": "line", "strokeWidth": 2, "opacity": 0.7 },
      "encoding": {
        "x": {
          "field": "time", "type": "ordinal",
          "sort": ["Pre-Fire (2019)","Post-Fire (2022)"],
          "axis": { "title": null, "labelColor": "#555", "labelFont": "DM Mono", "labelFontSize": 12, "grid": false, "domainColor": "#ccc" }
        },
        "y": {
          "field": "status", "type": "quantitative",
          "scale": { "domain": [0.5, 3.5] },
          "axis": {
            "title": null,
            "values": [1,2,3],
            "labelExpr": "datum.value===1?'Critically Endangered':datum.value===2?'Endangered':'Vulnerable'",
            "labelColor": "#555", "labelFont": "DM Mono", "labelFontSize": 11,
            "grid": true, "gridColor": "#e8e0d0",
            "domainColor": "transparent", "tickColor": "transparent"
          }
        },
        "detail": { "field": "species" },
        "color": {
          "field": "group", "type": "nominal",
          "scale": {
            "domain": ["Mammal","Bird","Frog","Reptile","Invertebrate"],
            "range":  ["#b83d10","#9a7820","#5a8a50","#3d5a32","#1e4a6a"]
          },
          "legend": { "title": "Animal Group", "labelColor": "#888", "titleColor": "#888", "labelFont": "DM Mono", "orient": "top-right" }
        },
        "tooltip": [
          { "field": "species", "title": "Species" },
          { "field": "group",   "title": "Group" },
          { "field": "time",    "title": "Period" },
          { "field": "label",   "title": "Threat Status" }
        ]
      }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 90 },
      "encoding": {
        "x": { "field": "time", "type": "ordinal", "sort": ["Pre-Fire (2019)","Post-Fire (2022)"] },
        "y": { "field": "status", "type": "quantitative" },
        "color": {
          "field": "group", "type": "nominal",
          "scale": {
            "domain": ["Mammal","Bird","Frog","Reptile","Invertebrate"],
            "range":  ["#b83d10","#9a7820","#5a8a50","#3d5a32","#1e4a6a"]
          }
        },
        "tooltip": [
          { "field": "species", "title": "Species" },
          { "field": "group",   "title": "Group" },
          { "field": "time",    "title": "Period" },
          { "field": "label",   "title": "Threat Status" }
        ]
      }
    }
  ],
  "config": { "view": { "stroke": null } }
}
