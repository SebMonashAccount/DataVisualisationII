{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container", "height": 300, "background": "transparent",
  "data": {
    "values": [
      {"year":2000,"funding":120,"new_listings":18},
      {"year":2002,"funding":135,"new_listings":22},
      {"year":2004,"funding":148,"new_listings":25},
      {"year":2006,"funding":162,"new_listings":20},
      {"year":2008,"funding":185,"new_listings":28},
      {"year":2010,"funding":198,"new_listings":24},
      {"year":2012,"funding":210,"new_listings":30},
      {"year":2014,"funding":195,"new_listings":35},
      {"year":2016,"funding":188,"new_listings":32},
      {"year":2018,"funding":201,"new_listings":38},
      {"year":2020,"funding":285,"new_listings":55},
      {"year":2022,"funding":420,"new_listings":48},
      {"year":2024,"funding":510,"new_listings":42}
    ]
  },
  "params": [
    {
      "name": "hover",
      "select": { "type": "point", "on": "mouseover", "nearest": true, "fields": ["year"] }
    }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "opacity": 0.7, "color": "#4a8a9a", "cornerRadiusTopLeft": 2, "cornerRadiusTopRight": 2 },
      "encoding": {
        "x": {
          "field": "year", "type": "ordinal",
          "axis": { "title": "Year", "titleColor": "#888", "titleFont": "DM Mono", "titleFontSize": 10, "labelColor": "#888", "labelFont": "DM Mono", "labelAngle": 0, "grid": false }
        },
        "y": {
          "field": "funding", "type": "quantitative",
          "title": "Conservation Funding ($M AUD)",
          "axis": { "titleColor": "#4a8a9a", "labelColor": "#4a8a9a", "titleFont": "DM Mono", "labelFont": "DM Mono", "titleFontSize": 10, "grid": true, "gridColor": "rgba(255,255,255,.07)", "format": ",.0f" }
        },
        "opacity": {
          "condition": { "param": "hover", "empty": true, "value": 0.85 },
          "value": 0.3
        },
        "tooltip": [
          { "field": "year", "title": "Year" },
          { "field": "funding", "title": "Conservation Funding ($M AUD)", "format": ",.0f" },
          { "field": "new_listings", "title": "New Threatened Species Listed" }
        ]
      }
    },
    {
      "mark": { "type": "line", "color": "#e8520a", "strokeWidth": 2.5, "interpolate": "monotone" },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": {
          "field": "new_listings", "type": "quantitative",
          "title": "New Threatened Species Listed",
          "axis": { "orient": "right", "titleColor": "#e8520a", "labelColor": "#e8520a", "titleFont": "DM Mono", "labelFont": "DM Mono", "titleFontSize": 10, "grid": false }
        }
      }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 80, "color": "#e8520a" },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "new_listings", "type": "quantitative" },
        "size": {
          "condition": { "param": "hover", "empty": false, "value": 200 },
          "value": 60
        },
        "tooltip": [
          { "field": "year", "title": "Year" },
          { "field": "funding", "title": "Funding ($M AUD)", "format": ",.0f" },
          { "field": "new_listings", "title": "New Threatened Listings" }
        ]
      }
    },
    {
      "mark": { "type": "rule", "color": "rgba(255,255,255,.15)", "strokeWidth": 1 },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "opacity": {
          "condition": { "param": "hover", "empty": false, "value": 1 },
          "value": 0
        }
      }
    }
  ],
  "resolve": { "scale": { "y": "independent" } },
  "config": { "background": "transparent", "view": { "stroke": null } }
}
