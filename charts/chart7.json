{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 450,
  "background": "transparent",
  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 700
  },
  "data": {
    "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
    "format": { "type": "json", "property": "features" }
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {
          "values": [
            { "state": "New South Wales",              "species": 1057, "critically_endangered": 117, "endangered": 481, "vulnerable": 459 },
            { "state": "Victoria",                     "species": 623,  "critically_endangered": 49,  "endangered": 276, "vulnerable": 298 },
            { "state": "Queensland",                   "species": 1136, "critically_endangered": 93,  "endangered": 472, "vulnerable": 571 },
            { "state": "South Australia",              "species": 436,  "critically_endangered": 42,  "endangered": 177, "vulnerable": 217 },
            { "state": "Western Australia",            "species": 879,  "critically_endangered": 78,  "endangered": 348, "vulnerable": 453 },
            { "state": "Tasmania",                     "species": 348,  "critically_endangered": 31,  "endangered": 147, "vulnerable": 170 },
            { "state": "Northern Territory",           "species": 401,  "critically_endangered": 28,  "endangered": 162, "vulnerable": 211 },
            { "state": "Australian Capital Territory", "species": 119,  "critically_endangered": 14,  "endangered": 53,  "vulnerable": 52  }
          ]
        },
        "key": "state",
        "fields": ["species","critically_endangered","endangered","vulnerable"]
      }
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "rgba(255,255,255,0.25)",
    "strokeWidth": 1.2
  },
  "encoding": {
    "color": {
      "field": "species",
      "type": "quantitative",
      "scale": { "scheme": "reds", "type": "sqrt" },
      "legend": {
        "title": "Threatened Species",
        "format": ",.0f",
        "orient": "bottom-right",
        "titleFontSize": 10,
        "labelFontSize": 9,
        "titleColor": "#ccc",
        "labelColor": "#ccc",
        "titleFont": "DM Mono, monospace",
        "labelFont": "DM Mono, monospace",
        "gradientLength": 160,
        "gradientThickness": 8
      }
    },
    "tooltip": [
      { "field": "properties.STATE_NAME", "title": "State / Territory" },
      { "field": "species",               "title": "Total Threatened Species",  "format": ",.0f" },
      { "field": "critically_endangered", "title": "Critically Endangered",      "format": ",.0f" },
      { "field": "endangered",            "title": "Endangered",                 "format": ",.0f" },
      { "field": "vulnerable",            "title": "Vulnerable",                 "format": ",.0f" }
    ]
  },
  "config": {
    "background": "transparent",
    "view": { "stroke": null }
  }
}
