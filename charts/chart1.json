  "layer": [
    {
      "mark": {
        "type": "area",
        "line": { "color": "#b83d10", "strokeWidth": 2 },
        "color": {
          "gradient": "linear", "x1": 1, "y1": 0, "x2": 1, "y2": 1,
          "stops": [
            { "offset": 0, "color": "rgba(184,61,16,0.35)" },
            { "offset": 1, "color": "rgba(184,61,16,0.02)" }
          ]
        }
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "axis": { "title": null, "grid": false, "labelColor": "#888", "labelFont": "DM Mono", "tickColor": "transparent", "domainColor": "#ccc" } },
        "y": { "field": "area", "type": "quantitative", "axis": { "title": "Million Hectares", "titleColor": "#888", "labelColor": "#888", "labelFont": "DM Mono", "titleFont": "DM Mono", "titleFontSize": 10, "grid": true, "gridColor": "#e8e0d0" } },
        "tooltip": [{ "field": "season", "title": "Season" }, { "field": "area", "title": "Area Burned (M ha)", "format": ".1f" }]
      }
    },
    {
      "mark": { "type": "point", "filled": true, "size": 55 },
      "encoding": {
        "x": { "field": "year", "type": "quantitative" },
        "y": { "field": "area", "type": "quantitative" },
        "color": { "condition": { "test": "datum.year === 2020 || datum.year === 2024", "value": "#d4621e" }, "value": "rgba(184,61,16,0.25)" }
      }
    },
    {
      "mark": { "type": "text", "align": "center", "dy": -14, "fontSize": 11, "font": "DM Mono", "fontWeight": 500 },
      "transform": [{ "filter": "datum.year === 2020" }],
      "encoding": { "x": { "field": "year", "type": "quantitative" }, "y": { "field": "area", "type": "quantitative" }, "text": { "value": "Black Summer" }, "color": { "value": "#b83d10" } }
    },
    {
      "mark": { "type": "text", "align": "center", "dy": -14, "fontSize": 10, "font": "DM Mono" },
      "transform": [{ "filter": "datum.year === 2024" }],
      "encoding": { "x": { "field": "year", "type": "quantitative" }, "y": { "field": "area", "type": "quantitative" }, "text": { "value": "2023-24: 96M ha" }, "color": { "value": "#9a7820" } }
    }
  ],
