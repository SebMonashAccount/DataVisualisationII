{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 360,
  "padding": {"left": 10, "right": 40, "top": 20, "bottom": 30},
  "background": "transparent",
  "data": {
    "values": [
      {
        "state": "Queensland",
        "count": 1136,
        "fire_overlap": 65
      },
      {
        "state": "New South Wales",
        "count": 1057,
        "fire_overlap": 82
      },
      {
        "state": "Western Australia",
        "count": 879,
        "fire_overlap": 45
      },
      {
        "state": "Victoria",
        "count": 623,
        "fire_overlap": 78
      },
      {
        "state": "South Australia",
        "count": 436,
        "fire_overlap": 55
      },
      {
        "state": "Northern Territory",
        "count": 401,
        "fire_overlap": 38
      },
      {
        "state": "Tasmania",
        "count": 348,
        "fire_overlap": 60
      },
      {
        "state": "Australian Capital Territory",
        "count": 119,
        "fire_overlap": 85
      }
    ]
  },
  "mark": {
    "type": "bar",
    "cornerRadiusTopRight": 3,
    "cornerRadiusBottomRight": 3
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "ordinal",
      "sort": "-x",
      "axis": {
        "title": null,
        "labelColor": "#888",
        "labelFont": "DM Mono"
      }
    },
    "x": {
      "field": "count",
      "type": "quantitative",
      "scale": {
        "domain": [0, 1250],
        "nice": false
      },
      "axis": {
        "title": "Threatened species",
        "titleColor": "#888",
        "labelColor": "#888",
        "labelFont": "DM Mono",
        "titleFont": "DM Mono",
        "titleFontSize": 10,
        "grid": true,
        "gridColor": "#e8e0d0",
        "values": [0, 200, 400, 600, 800, 1000, 1200]
      }
    },
    "color": {
      "field": "fire_overlap",
      "type": "quantitative",
      "title": "Percentage of habitat in 2019-20 fire footprint",
      "scale": {
        "range": [
          "#e8d8c0",
          "#b83d10"
        ]
      },
      "legend": {
        "labelColor": "#888",
        "titleColor": "#888",
        "labelFont": "DM Mono",
        "titleFont": "DM Mono",
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 160,
        "title": "Habitat in fire footprint",
        "titleLimit": 260
      }
    },
    "tooltip": [
      {
        "field": "state",
        "title": "State"
      },
      {
        "field": "count",
        "title": "Threatened species"
      },
      {
        "field": "fire_overlap",
        "title": "Habitat in 2019-20 fire footprint"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
